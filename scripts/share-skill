#!/bin/bash
# share-skill — 主管把自己 my-skills/ 內的 SKILL 分享給其他 cohort 主管
#
# 流程:
#   1. 主管在自己 L3 repo 寫完 SKILL.md
#   2. 跑 ./scripts/share-skill <skill-name>
#   3. Script 自動 PR 到 cohort-template-{year} 的 shared-skills/{我的 slug}/
#   4. 講師 (Young) merge PR
#   5. 其他主管 ./scripts/update 拉 upstream → 看到 shared-skills/
#
# Usage:
#   ./scripts/share-skill recruit-screening
#   ./scripts/share-skill recruit-screening --message "招募初篩 SOP，HR 部門可用"

set -uo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$REPO_ROOT"

SKILL_NAME="${1:-}"
shift || true
MSG=""
while [ $# -gt 0 ]; do
  case "$1" in
    --message|-m) MSG="$2"; shift 2 ;;
    *) shift ;;
  esac
done

if [ -z "$SKILL_NAME" ]; then
  echo "Usage: $0 <skill-name> [--message 'description']"
  echo ""
  echo "你 my-skills/ 內的 SKILL:"
  ls my-skills/ 2>/dev/null | grep -v README | sed 's/\.md$//' | sed 's/^/  - /' || echo "  (空 - W5 後才會有)"
  exit 1
fi

SKILL_FILE="my-skills/${SKILL_NAME}.md"
if [ ! -f "$SKILL_FILE" ]; then
  echo "❌ 找不到 $SKILL_FILE"
  echo ""
  echo "你 my-skills/ 內的 SKILL:"
  ls my-skills/ 2>/dev/null | grep -v README | sed 's/\.md$//' | sed 's/^/  - /' || echo "  (空)"
  exit 1
fi

# Check upstream remote (cohort template)
if ! git remote | grep -q upstream; then
  echo "❌ 沒設定 upstream remote (cohort template)"
  echo "   請聯絡講師確認 setup.sh 跑過了"
  exit 1
fi

UPSTREAM_URL=$(git remote get-url upstream)
# Extract ORG/REPO from URL
UPSTREAM_REPO=$(echo "$UPSTREAM_URL" | sed -E 's|.*github.com[:/]([^/]+/[^/.]+).*|\1|')

# 取得主管 slug (從 origin URL 來)
ORIGIN_URL=$(git remote get-url origin 2>/dev/null || echo "")
MY_SLUG=$(echo "$ORIGIN_URL" | sed -E 's|.*github.com[:/][^/]+/([^/-]+)-leader-journey.*|\1|')
if [ -z "$MY_SLUG" ] || [ "$MY_SLUG" = "$ORIGIN_URL" ]; then
  # Fallback: ask user
  read -p "你的 manager slug (例: alice): " MY_SLUG
fi

echo "🤝 Share Skill"
echo "  Skill: $SKILL_NAME"
echo "  我的 slug: $MY_SLUG"
echo "  Upstream: $UPSTREAM_REPO"
echo ""
read -p "確認分享？[y/N] " yn
case "$yn" in
  [Yy]*) ;;
  *) echo "取消"; exit 0 ;;
esac

# Workflow: fork upstream → branch → add file → PR
echo ""
echo "[1/4] Fork upstream + clone temp..."
TMPDIR=$(mktemp -d)
if ! gh repo fork "$UPSTREAM_REPO" --clone --remote=false --default-branch-only 2>&1 | tail -5; then
  echo "  (可能 fork 已存在，繼續)"
fi
FORK_NAME=$(gh api /user --jq .login)/$(basename "$UPSTREAM_REPO")
gh repo clone "$FORK_NAME" "$TMPDIR/fork" -- --quiet 2>&1 | tail -3 || { echo "❌ Clone fork 失敗"; exit 1; }
cd "$TMPDIR/fork"

echo "[2/4] 建 branch + 加 shared SKILL..."
BRANCH="share-${MY_SLUG}-${SKILL_NAME}-$(date +%s)"
git checkout -b "$BRANCH" --quiet
mkdir -p "shared-skills/$MY_SLUG"
cp "$REPO_ROOT/$SKILL_FILE" "shared-skills/$MY_SLUG/${SKILL_NAME}.md"

# Add metadata header
cat > "shared-skills/$MY_SLUG/${SKILL_NAME}.md.meta" <<EOF
---
shared_by: $MY_SLUG
shared_at: $(date +%Y-%m-%d)
message: ${MSG:-（無說明）}
original: my-skills/${SKILL_NAME}.md (in my own repo)
---
EOF
# Merge meta into front of SKILL
cat "shared-skills/$MY_SLUG/${SKILL_NAME}.md.meta" "shared-skills/$MY_SLUG/${SKILL_NAME}.md" > /tmp/combined.md
mv /tmp/combined.md "shared-skills/$MY_SLUG/${SKILL_NAME}.md"
rm "shared-skills/$MY_SLUG/${SKILL_NAME}.md.meta"

git add "shared-skills/$MY_SLUG/${SKILL_NAME}.md"
git commit -m "share: $MY_SLUG 分享 $SKILL_NAME

${MSG:-無說明}" --quiet

echo "[3/4] Push branch..."
git push --set-upstream origin "$BRANCH" 2>&1 | tail -3

echo "[4/4] 開 PR..."
PR_BODY=$(cat <<EOF
## Skill 分享: \`$SKILL_NAME\`

**分享者**: $MY_SLUG
**說明**: ${MSG:-（無說明）}

### 來源
我自己 repo 的 \`my-skills/${SKILL_NAME}.md\`

### Merge 後
其他 cohort 主管下次跑 \`./scripts/update\` 會在 \`shared-skills/$MY_SLUG/\` 看到此 SKILL，可參考 / 試用 / 改寫。

---
*Auto-generated by \`./scripts/share-skill\`*
EOF
)
PR_URL=$(gh pr create --repo "$UPSTREAM_REPO" --head "$(gh api /user --jq .login):$BRANCH" --title "share: $MY_SLUG / $SKILL_NAME" --body "$PR_BODY" 2>&1 | tail -1)

cd - >/dev/null
rm -rf "$TMPDIR"

echo ""
echo "✅ PR 開好了:"
echo "   $PR_URL"
echo ""
echo "等講師 merge 後，其他 cohort 主管會在他們的 ./scripts/update 看到。"
